# Copy this file to .env and fill in real values
# Generate JWT_SECRET with: openssl rand -hex 32

# Database — asyncpg URL for the app
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/indoor_cricket

# Database — plain psycopg2 URL for Alembic migrations
POSTGRES=postgresql://user:password@localhost:5432/indoor_cricket

APP_PORT=8001
REDIS_URL=redis://localhost:6379

JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

LOG_LEVEL=INFO
DEBUG=false
STATIC_DIR=static
MAX_AVATAR_SIZE_MB=5
APP_NAME=Indoor Cricket Platform
